{
  "name": "synthosite-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Express API for SynthoSite.",
  "main": "src/server.js",
  "scripts": {
    "db:init": "node scripts/init-db.js",
    "dev": "nodemon src/server.js",
